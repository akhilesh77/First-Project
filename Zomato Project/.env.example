# Database (SQLite path relative to project root or absolute)
DATABASE_URL=sqlite:///data/restaurants.db

# Max candidates after filter (before LLM in later phases)
N_MAX_CANDIDATES=30

# API (Phase 3)
TOP_K_DEFAULT=5
TOP_K_MAX=10
MAX_ADDITIONAL_PREFERENCES_LENGTH=500
# API_KEY=your-secret-key
# CORS_ORIGINS=*

# Hugging Face dataset identifier
HF_DATASET=ManikaSaini/zomato-restaurant-recommendation

# xAI Grok (Phase 4) — get key at https://console.x.ai/
XAI_API_KEY=
# LLM_API_KEY=your-llm-key        # alias for XAI_API_KEY
LLM_ENABLED=true
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-3
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
